<Window x:Class="TextDiff.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="textdiff"
        Width="1480"
        Height="860"
        MinWidth="1080"
        MinHeight="680"
        Background="#FFF7F7F8">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBorderBrush" Color="#FFD8D8DC" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="ChromeBrush" Color="#FFF1F2F4" />
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderBrush" Value="#FFCDCED4" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource WindowBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="14,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Click="OpenLeftFile_Click">打开左侧</Button>
                    <Button Click="OpenRightFile_Click">打开右侧</Button>
                    <Button Click="PasteLeft_Click">粘贴到左侧</Button>
                    <Button Click="PasteRight_Click">粘贴到右侧</Button>
                    <Button Click="SwapSides_Click">交换左右</Button>
                    <Button Click="CompareNow_Click">立即比较</Button>
                    <Button Click="ClearAll_Click">清空</Button>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <CheckBox x:Name="AutoCompareCheckBox"
                              Content="自动比较"
                              IsChecked="True" />
                    <CheckBox x:Name="WordWrapCheckBox"
                              Content="自动换行" />
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom"
                   Background="{StaticResource ChromeBrush}"
                   BorderBrush="{StaticResource WindowBorderBrush}"
                   BorderThickness="1,1,1,0"
                   Padding="10,2">
            <StatusBarItem Padding="0">
                <TextBlock x:Name="SummaryTextBlock"
                           Foreground="#FF4A4D57"
                           Text="把文本粘贴到左右两侧后，结果会显示在这里。" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem Padding="0">
                <TextBlock x:Name="CursorTextBlock"
                           Foreground="#FF6C6F7A"
                           Text="左侧 Ln 1, Col 1 | 右侧 Ln 1, Col 1" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem Padding="0">
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="InlineModeCheckBox"
                              Content="内联模式"
                              IsEnabled="False"
                              ToolTip="当前版本先提供并排对比，内联模式可在后续扩展。" />
                    <ComboBox x:Name="ContentTypeComboBox"
                              IsEnabled="False"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Text" />
                    </ComboBox>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource WindowBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FFF7F8FA"
                            BorderBrush="{StaticResource WindowBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,10">
                        <DockPanel>
                            <TextBlock Text="左侧文本"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FF2F3240" />
                            <TextBlock x:Name="LeftMetaTextBlock"
                                       DockPanel.Dock="Right"
                                       Foreground="#FF7B7E89"
                                       Text="0 行 | 0 字符" />
                        </DockPanel>
                    </Border>

                    <avalonedit:TextEditor x:Name="LeftEditor"
                                           Grid.Row="1"
                                           Background="White"
                                           BorderThickness="0"
                                           FontFamily="Consolas"
                                           FontSize="14"
                                           HorizontalScrollBarVisibility="Auto"
                                           ShowLineNumbers="True"
                                           SyntaxHighlighting="{x:Null}"
                                           VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="#FFE7E8EC"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource WindowBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FFF7F8FA"
                            BorderBrush="{StaticResource WindowBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,10">
                        <DockPanel>
                            <TextBlock Text="右侧文本"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FF2F3240" />
                            <TextBlock x:Name="RightMetaTextBlock"
                                       DockPanel.Dock="Right"
                                       Foreground="#FF7B7E89"
                                       Text="0 行 | 0 字符" />
                        </DockPanel>
                    </Border>

                    <avalonedit:TextEditor x:Name="RightEditor"
                                           Grid.Row="1"
                                           Background="White"
                                           BorderThickness="0"
                                           FontFamily="Consolas"
                                           FontSize="14"
                                           HorizontalScrollBarVisibility="Auto"
                                           ShowLineNumbers="True"
                                           SyntaxHighlighting="{x:Null}"
                                           VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
